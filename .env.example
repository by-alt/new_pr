# Copy this file to ".env" and fill in your real values.
# Get these by following docs/REDDIT_SETUP.md
# The .env file is gitignored — never commit your real credentials.

REDDIT_CLIENT_ID=your_client_id_here
REDDIT_CLIENT_SECRET=your_client_secret_here
REDDIT_USER_AGENT=brand-health-tracker by u/your_reddit_username

# OPTIONAL — enables LLM aspect-based sentiment (ABSA). Leave blank to skip entirely;
# the pipeline runs identically without it. Free key: https://aistudio.google.com/apikey
GEMINI_API_KEY=
GEMINI_MODEL=gemini-1.5-flash

# OPTIONAL — Slack or Discord incoming-webhook URL for proactive anomaly alerts.
# Leave blank to disable (scripts/alerts.py becomes a safe dry run).
ALERT_WEBHOOK_URL=

# OPTIONAL — polite-fetch tuning (safe defaults apply if unset/blank).
FETCH_MIN_DELAY_SECONDS=4
FETCH_JITTER_SECONDS=3
REVIEWS_PER_BRAND=200
